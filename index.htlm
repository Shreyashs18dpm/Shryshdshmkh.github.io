    <!-- Hero Section -->
    <section class="hero">
        <div class="container">
            <div class="hero-content">
                <h1>Welcome to My Academic Page</h1>
                <p class="subtitle">Doctoral Researcher | Data Scientist | Statistician</p>
                <p class="hero-text">Applying advanced analytical techniques to solve complex real-world problems in demography, public health, and sustainability</p>
            </div>
        </div>
    </section>

    <!-- About Section -->
    <section id="about" class="about">
        <div class="container">
            <h2>About Me</h2>
            <div class="about-content">
                <div class="about-text">
                    <p>
                        I am a doctoral researcher at <strong>Indian Institute of Management Kozhikode</strong>, specializing in Quantitative Methods and Operations Management. My research is driven by a strong interest in applying advanced analytical techniques—particularly statistical machine learning, spatial econometrics, and multivariate time series modeling—to solve complex real-world problems.
                    </p>
                    <p>
                        My research spans diverse domains including demography, public health, sustainability, and hospitality analytics. I am particularly interested in how quantitative insights can inform policy and improve outcomes in sectors with high social impact. I hold a Master's in Population Studies from IIPS Mumbai and an MSc in Statistics from Sardar Patel University.
                    </p>
                    <p>
                        Currently, I am developing an interactive data visualization portal focused on demographic and socio-economic indicators with GIS-based geocoding capabilities, working with granular data from the Indian Census and National Family Health Survey (NFHS).
                    </p>
                    <div class="cv-link">
                        <a href="/assets/pdf/Shreyash_CV.pdf" class="btn">Download CV (PDF)</a>
                    </div>
                </div>
                <div class="stats">
                    <div class="stat-item">
                        <h3>5+</h3>
                        <p>Years Research</p>
                    </div>
                    <div class="stat-item">
                        <h3>1+</h3>
                        <p>Publications</p>
                    </div>
                    <div class="stat-item">
                        <h3>3</h3>
                        <p>Degrees</p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Research Interests Section -->
    <section id="research" class="research">
        <div class="container">
            <h2>Research Interests</h2>
            <div class="research-grid">
                <div class="research-card">
                    <h3>Quantile Regression</h3>
                    <p>Statistical and machine learning methods for time series forecasting and extreme value prediction</p>
                </div>
                <div class="research-card">
                    <h3>Spatial Econometrics</h3>
                    <p>Geographic information systems and geocoding for socio-economic analysis</p>
                </div>
                <div class="research-card">
                    <h3>Demographic Analysis</h3>
                    <p>Population studies and public health research using large-scale datasets</p>
                </div>
                <div class="research-card">
                    <h3>Time Series Modeling</h3>
                    <p>Volatility modeling and multivariate forecasting for disease outbreak prediction</p>
                </div>
            </div>
        </div>
    </section>

    <!-- Publications Section -->
    <section id="publications" class="publications">
        <div class="container">
            <h2>Recent Publications</h2>
            <div class="publications-list">
                <div class="publication-item">
                    <h4>A Survey of Statistical and Machine Learning Methods for Quantile Regression in Time Series and Their Suitability for Predicting Dengue Outbreaks</h4>
                    <p class="authors">Deshmukh, S., & Deb, S.</p>
                    <p class="venue"><strong>Japanese Journal of Statistics and Data Science</strong>, 2025</p>
                    <p class="description">
                        This paper surveys statistical and machine learning methods for quantile regression in time series, with a focus on their suitability for predicting disease outbreaks. The study evaluates various methodologies for extreme value forecasting in epidemiological applications.
                    </p>
                    <div class="publication-links">
                        <a href="https://link.springer.com/article/10.1007/s42081-025-00297-y" class="link" target="_blank">Published Article</a>
                        <a href="https://doi.org/10.1007/s42081-025-00297-y" class="link" target="_blank">DOI</a>
                    </div>
                </div>

                <div class="publication-item">
                    <h4>Analyzing Consumption Inequality in India: Key Insights from the Household Consumption Expenditure Survey</h4>
                    <p class="authors">Deshmukh, S.</p>
                    <p class="venue"><strong>IIM Kozhikode</strong>, 2024</p>
                    <p class="description">
                        This study examines consumption expenditure inequality across social groups in Indian states using the Household Consumption Expenditure Survey (HCES) 2023-24. The analysis reveals significant variations in Gini coefficients across states and social groups, highlighting disparities in resource consumption.
                    </p>
                    <div class="publication-links">
                        <a href="/assets/pdf/term_paper_POM.pdf" class="link">PDF</a>
                    </div>
                </div>

                <div class="publication-item">
                    <h4>Meta-Analysis of Survival Rate of AIDS Disease</h4>
                    <p class="authors">Deshmukh, S.</p>
                    <p class="venue"><strong>MSc Thesis, Sardar Patel University</strong>, 2020</p>
                    <p class="description">
                        A comprehensive meta-analysis reviewing 20 cohort studies with 25,000 participants to estimate survival rates from HIV diagnosis to AIDS onset. The study applied random-effects models and demonstrated that HAART significantly improves patient survival outcomes.
                    </p>
                    <div class="publication-links">
                        <a href="#" class="link">Details</a>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Projects Section -->
    <section id="projects" class="projects">
        <div class="container">
            <h2>Research Projects</h2>
            <div class="projects-grid">
                <div class="project-card">
                    <h3>Interactive Data Visualization Portal</h3>
                    <p>
                        Developing a comprehensive data visualization portal for demographic and socio-economic indicators with integrated GIS-based geocoding and mapping capabilities. Uses granular data from Indian Census and NFHS datasets.
                    </p>
                    <div class="project-tags">
                        <span class="tag">R/Python</span>
                        <span class="tag">GIS</span>
                        <span class="tag">Data Visualization</span>
                    </div>
                    <a href="#" class="project-link">In Progress →</a>
                </div>

                <div class="project-card">
                    <h3>Dynamic Air Pollutant Modeling</h3>
                    <p>
                        Examines dynamic relationships between air pollutants (PM₂.₅, PM₁₀, O₃, NO₂, SO₂, CO) and Air Quality Index using Vector Autoregressive (VAR) models with impulse response analysis.
                    </p>
                    <div class="project-tags">
                        <span class="tag">VAR Modeling</span>
                        <span class="tag">Econometrics</span>
                        <span class="tag">Environmental Science</span>
                    </div>
                    <a href="#" class="project-link">Completed →</a>
                </div>

                <div class="project-card">
                    <h3>Disease Outbreak Prediction Models</h3>
                    <p>
                        Research on predicting disease outbreaks (particularly dengue) using quantile regression methods. Evaluates various statistical and machine learning approaches through experimental and simulation studies.
                    </p>
                    <div class="project-tags">
                        <span class="tag">Quantile Regression</span>
                        <span class="tag">Epidemiology</span>
                        <span class="tag">Time Series</span>
                    </div>
                    <a href="#" class="project-link">Active Research →</a>
                </div>
            </div>
        </div>
    </section>

    <!-- Teaching Section -->
    <section id="teaching" class="teaching">
        <div class="container">
            <h2>Skills & Expertise</h2>
            <div class="courses-list">
                <div class="course-item">
                    <h3>Statistical Methods & Econometrics</h3>
                    <p class="course-code">Core Expertise</p>
                    <p class="course-description">
                        Advanced proficiency in multivariate time series analysis, quantile regression, 
                        spatial econometrics, meta-analysis, survival analysis, and Vector Autoregressive (VAR) modeling.
                    </p>
                </div>

                <div class="course-item">
                    <h3>Programming & Data Science</h3>
                    <p class="course-code">Technical Tools</p>
                    <p class="course-description">
                        Experienced with R, Python, STATA, SPSS, MATLAB, and LaTeX. Proficient in data manipulation, 
                        statistical modeling, data visualization, and reproducible research practices.
                    </p>
                </div>

                <div class="course-item">
                    <h3>Domain Applications</h3>
                    <p class="course-code">Research Areas</p>
                    <p class="course-description">
                        Specialized experience in demography, epidemiology, public health, hospitality analytics, 
                        environmental science, and socio-economic inequality research with large-scale datasets.
                    </p>
                </div>
            </div>
        </div>
    </section>

